# =====================================================================
# VELANTHOR AFFILIATE SYSTEM — Environment Variables
# Kopiere diese Datei zu .env.local und trage deine Werte ein.
# =====================================================================

# --- Supabase (Free Tier: https://supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Service Role Key -- NIEMALS im Client-Bundle verwenden, nur in API-Routes!
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- App ---
NEXT_PUBLIC_APP_URL=https://velanthor.org

# --- SMTP (IONOS Postfach) ---
# IONOS Standardwerte: Host smtp.ionos.de, Port 587 (STARTTLS) oder 465 (SSL)
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=partner@velanthor.org
SMTP_PASSWORD=dein-ionos-postfach-passwort
SMTP_FROM_EMAIL=partner@velanthor.org

# --- E-Mail für Admin-Benachrichtigungen bei neuer Registrierung ---
ADMIN_NOTIFICATION_EMAIL=admin@velanthor.org

# --- hCaptcha (kostenlos: https://www.hcaptcha.com) ---
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HCAPTCHA_SECRET_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Sicherheit ---
# Zufälligen 32+ Zeichen langen String generieren, z. B. mit: openssl rand -hex 32
IP_HASH_SECRET=change-me-to-a-random-secret

# HMAC-Secret für den Conversion-Webhook (Server-zu-Server-Aufruf von deiner
# VELANTHOR-Kernplattform beim Checkout). Muss auf beiden Seiten identisch sein.
CONVERSION_WEBHOOK_SECRET=change-me-to-a-random-secret

# --- Nur lokale Entwicklung ---
# Setze auf "true" um hCaptcha im Dev-Modus zu überspringen
SKIP_CAPTCHA=false
